# ------------------------------------------------------------
# Next.js Performance Showcase — environment variable reference
# Copy to .env.local and fill in values before running locally.
# ------------------------------------------------------------

# External metrics API base URL (used by lib/server/cache.ts)
# Leave empty to use the stub response in fetchHighPerformanceData
# NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# Memory GC RSS threshold in bytes (default: 1_610_612_736 = 1.5 GB)
# Tune down for containers with lower memory limits
# MEMORY_GC_THRESHOLD_BYTES=1610612736

# Path to the persisted metrics snapshot (lib/server/persistence.ts).
# Defaults to <os.tmpdir()>/nextjs-perf-metrics.json. Point this at a mounted
# volume to survive container restarts. The CRDT merge on load is idempotent.
# METRICS_STATE_PATH=/var/lib/nextjs-perf/metrics.json

# ------------------------------------------------------------
# Node.js startup flags (set in package.json "start" script):
#   --expose-gc             enables global.gc() in /api/health
#   --max-old-space-size=N  caps V8 old-space heap (MB)
#
# The "start" script already sets these:
#   node --expose-gc --max-old-space-size=2048 .next/standalone/server.js
# ------------------------------------------------------------
